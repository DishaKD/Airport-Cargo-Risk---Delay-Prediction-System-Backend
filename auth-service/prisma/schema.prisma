generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}


datasource db {
  provider = "postgresql"
}

enum Role {
  OPERATIONS
  CARGO
  CUSTOMS
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(OPERATIONS)
  created_at    DateTime @default(now())

  @@map("users")
}
